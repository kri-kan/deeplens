# --- DeepLens Central Infrastructure Example Configuration ---
# Copy this file to .env and update the values for your environment.

# Infrastructure Host (Central Server)
INFRA_HOST=192.168.0.170

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Krikank1$

# MinIO (Object Storage)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=krikan
MINIO_ROOT_PASSWORD=Krikank1$

# Redis (Caching)
REDIS_PORT=6379

# Kafka (Event Stream)
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# Qdrant (Vector DB)
QDRANT_DASH_PORT=6333
QDRANT_GRPC_PORT=6334

# InfluxDB (Time-Series)
INFLUXDB_PORT=8086
INFLUXDB_USER=krikan
INFLUXDB_PASSWORD=Krikank1$

# Open WebUI (Local LLM Gateway)
OPEN_WEBUI_PORT=11435

# Observability
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686
PGADMIN_PORT=5050

# --- Local Application Settings ---
REASONING_MOCK_MODE=true
FEATURE_EXTRACTION_PORT=8001
REASONING_API_PORT=8002