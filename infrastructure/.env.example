# DeepLens Infrastructure - Environment Configuration (EXTERNAL)
# These variables point to the centralized infrastructure at 192.168.0.170

# =============================================================================
# Database Credentials
# =============================================================================
POSTGRES_HOST=192.168.0.170
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Krikank1$

# Core Databases
POSTGRES_IDENTITY_DB=nextgen_identity
POSTGRES_METADATA_DB=deeplens_metadata

# =============================================================================
# MinIO Configuration
# =============================================================================
MINIO_ENDPOINT=192.168.0.170
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=krikan
MINIO_ROOT_PASSWORD=Krikank1$

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=192.168.0.170
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=192.168.0.170:9092
KAFKA_UI_URL=http://192.168.0.170:8080

# =============================================================================
# InfluxDB Configuration  
# =============================================================================
INFLUXDB_URL=http://192.168.0.170:8086
INFLUXDB_ADMIN_USER=krikan
INFLUXDB_ADMIN_PASSWORD=Krikank1$
INFLUXDB_ORG=deeplens
INFLUXDB_BUCKET=metrics

# =============================================================================
# Qdrant Configuration
# =============================================================================
QDRANT_HOST=192.168.0.170
QDRANT_URL=http://192.168.0.170:6333
QDRANT_DASHBOARD=http://192.168.0.170:6333/dashboard

# =============================================================================
# Monitoring & Observability
# =============================================================================
GRAFANA_URL=http://192.168.0.170:3000
GRAFANA_ADMIN_USER=krikan
GRAFANA_ADMIN_PASSWORD=Krikank1$
PROMETHEUS_URL=http://192.168.0.170:9090
JAEGER_URL=http://192.168.0.170:16686

# =============================================================================
# Network Configuration
# =============================================================================
NETWORK_NAME=deeplens-network

# =============================================================================
# Development Flags
# =============================================================================
ENVIRONMENT=development
DEBUG_MODE=true
LOG_LEVEL=debug