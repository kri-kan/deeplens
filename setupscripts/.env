# =============================================================================
# DEEPLENS INFRASTRUCTURE SETTINGS (UNIFIED)
# =============================================================================
# This file centralizes all credentials, ports, and paths for the stack.
# After modification, run: ./orchestrate-linux.sh start

# -----------------------------------------------------------------------------
# GLOBAL CREDENTIALS
# -----------------------------------------------------------------------------
INFRA_ADMIN_USER=krikan
INFRA_ADMIN_PASSWORD=Krikank1$
INFRA_ADMIN_EMAIL=krikan@deeplens.internal
INFRA_IP=192.168.0.170

 
# pgAdmin specific (requires valid email format)
PGADMIN_DEFAULT_EMAIL=admin@deeplens.com
PGADMIN_DEFAULT_PASSWORD=Krikank1$
 
# -----------------------------------------------------------------------------
# SHARED INFRASTRUCTURE PATHS
# -----------------------------------------------------------------------------
PRODUCTION_DATA_DIR=/var/www/html/production_data
TEST_DATA_DIR=/var/www/html/test_data

# -----------------------------------------------------------------------------
# CORE SERVICES
# -----------------------------------------------------------------------------

# Kafka
KAFKA_PROD_PORT=9092
KAFKA_PROD_LOCAL_PORT=29092
KAFKA_TEST_PORT=9094
KAFKA_TEST_LOCAL_PORT=29096
KAFKA_UI_PORT=8080
KAFKA_DATA_PATH=/data/kafka
KAFKA_TEST_DATA_PATH=/home/krikan/data/test/kafka

# PostgreSQL & pgAdmin
POSTGRES_PORT=5432
PGADMIN_PORT=5050
POSTGRES_DATA_PATH=/data/postgres
PGADMIN_DATA_PATH=/data/pgadmin
POSTGRES_BACKUP_PATH=/home/krikan/data/postgresBackups

# Ollama & AI
OLLAMA_PORT=11434
OPEN_WEBUI_PORT=11435
OLLAMA_DATA_PATH=/data/ollama
OPEN_WEBUI_DATA_PATH=/data/open-webui

# -----------------------------------------------------------------------------
# BACKEND STACK
# -----------------------------------------------------------------------------

# Redis
REDIS_PORT=6379
REDIS_DATA_PATH=/data/redis

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_PATH=/data/minio

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_DATA_PATH=/data/qdrant

# InfluxDB
INFLUXDB_PORT=8086
INFLUXDB_DATA_PATH=/data/influxdb

# -----------------------------------------------------------------------------
# OBSERVABILITY STACK
# -----------------------------------------------------------------------------

# Grafana
GRAFANA_PORT=3000
GRAFANA_DATA_PATH=/data/grafana

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_DATA_PATH=/data/prometheus

# Loki
LOKI_PORT=3100
LOKI_DATA_PATH=/data/loki

# Jaeger
JAEGER_UI_PORT=16686
JAEGER_DATA_PATH=/data/jaeger
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# OTel Collector
OTEL_COLLECTOR_METRICS_PORT=8888
OTEL_COLLECTOR_HEALTH_PORT=8889

# -----------------------------------------------------------------------------
# GATEWAY & EXPOSURE
# -----------------------------------------------------------------------------
GATEWAY_PORT=80

# [Phase 3] Cloudflare Tunnel Token
# CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# -----------------------------------------------------------------------------
# APPLICATION SERVICES (Hosting)
# -----------------------------------------------------------------------------
HOSTING_ROOT=/data/hosting

IDENTITY_API_PORT=5198
SEARCH_API_PORT=5002
COMPETITOR_ORCHESTRATOR_PORT=8006
WEB_UI_PORT=3006
WHATSAPP_PROCESSOR_PORT=3001

IDENTITY_HOSTING_PATH=${HOSTING_ROOT}/identity
SEARCH_API_HOSTING_PATH=${HOSTING_ROOT}/deeplensapi
WORKER_SERVICE_HOSTING_PATH=${HOSTING_ROOT}/deeplensworkerservice
WEB_UI_HOSTING_PATH=${HOSTING_ROOT}/deeplenswebui
WHATSAPP_HOSTING_PATH=${HOSTING_ROOT}/whatsapp
REASONING_API_HOSTING_PATH=${HOSTING_ROOT}/reasoning-api

# -----------------------------------------------------------------------------
# META GRAPH API CREDENTIALS (Competitor Intel Orchestrator)
# -----------------------------------------------------------------------------
# Override these via environment variables on the server — do NOT commit real values.
# Meta__AppId=YOUR_APP_ID
# Meta__AppSecret=YOUR_APP_SECRET
# Meta__IgBizId=YOUR_IG_BIZ_ACCOUNT_ID
# Meta__AccessToken=YOUR_LONG_LIVED_TOKEN
